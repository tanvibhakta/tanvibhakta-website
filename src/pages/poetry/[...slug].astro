---
import { render } from "astro:content";
import ProseLayout from "../../layouts/ProseLayout.astro";
import AudioPlayer from "../../components/AudioPlayer.astro";
import { getPublishedEntries } from "../../utils/collections";

export async function getStaticPaths() {
  const poetry = await getPublishedEntries("poetry");
  return poetry.map((poem) => ({
    params: { title: poem.data.title, slug: poem.id },
    props: { poem },
  }));
}

const { poem } = Astro.props;
const { Content } = await render(poem);
---

<ProseLayout frontmatter={poem.data}>
  <Content />
  {
    poem.data.audio && (
      <AudioPlayer
        src={poem.data.audio}
        title={poem.data.audioTitle ?? "Listen to this poem"}
      />
    )
  }
</ProseLayout>
