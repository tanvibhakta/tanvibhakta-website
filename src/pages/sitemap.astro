---
import ProseLayout from "../layouts/ProseLayout.astro";

// A curated, top-level table of contents — one entry per section, with a
// short explanation. Individual posts live on their section index pages,
// not here. The exhaustive machine-readable list is at /sitemap.xml.
const sections = [
  { href: "/", title: "Home", blurb: "Who I am, in six lines." },
  {
    href: "/blog",
    title: "Blog",
    blurb: "Long-form posts, mostly on technology and the life around it.",
  },
  {
    href: "/poetry",
    title: "Poetry",
    blurb: "Poems, some with audio readings.",
  },
  {
    href: "/weeknotes",
    title: "Weeknotes",
    blurb: "Short, regular notes on life and work.",
  },
  {
    href: "/digital-garden",
    title: "Digital Garden",
    blurb: "Evolving notes I tend and update over time.",
  },
  {
    href: "/tags",
    title: "Tags",
    blurb: "Browse posts by topic.",
  },
  {
    href: "/work",
    title: "Work",
    blurb: "What I do, with links to my resume and code.",
  },
  {
    href: "/subscribe",
    title: "Subscribe",
    blurb: "RSS feeds for every section, or all posts at once.",
  },
];

const frontmatter = { title: "Sitemap" };
---

<ProseLayout frontmatter={frontmatter}>
  <p>
    A map of everything here. For the full list of individual posts, follow a
    section to its archive. Search engines can use the <a href="/sitemap.xml"
      >machine-readable sitemap</a
    >.
  </p>

  <ul>
    {
      sections.map((section) => (
        <li>
          <a href={section.href}>{section.title}</a>
          <span class="blurb">{section.blurb}</span>
        </li>
      ))
    }
  </ul>
</ProseLayout>

<style>
  ul {
    list-style: none;
    padding-left: 0;
  }

  li {
    margin-bottom: 0.75rem;
  }

  .blurb {
    display: block;
    font-size: 0.9rem;
    opacity: 0.7;
  }
</style>
